# Copy to deploy/demo/.env on the server and fill in values.
# Never commit deploy/demo/.env

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-openssl-or-secrets-token-hex-32

# Public URL users will open (include https:// if using TLS)
PUBLIC_APP_URL=https://demo.yourdomain.com

# Must match PUBLIC_APP_URL origin (comma-separated if multiple)
CORS_ORIGINS=https://demo.yourdomain.com

# Host port for nginx/web (80 needs root or cap_net_bind; use 8080 behind reverse proxy)
WEB_PORT=8080

# Optional: Postgres password override (default fms/fms in compose — change for production)
# POSTGRES_PASSWORD=
