# Database URL — MUST match the Docker profile you are running:
#   Dev compose (docker compose up):              .../fms
#   Demo compose (docker-compose.demo.yml overlay): .../fms_demo
# Local uvicorn + demo Docker DB only: copy .env.demo.example → .env
DATABASE_URL=postgresql+psycopg2://fms:fms@localhost:5432/fms
SECRET_KEY=replace-with-random-hex
JWT_SECRET=replace-with-random-hex
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
APP_ENV=development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=notifications@fms.local
