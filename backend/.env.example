# Database URL — MUST match the Docker profile you are running:
#   Hybrid dev (host API :8000, Vite :5173): docker compose -f docker-compose.yml -f docker-compose.local.yml up -d  → fms
#   Full dev stack (web :8080, API :8000):    docker compose up -d
#   Demo overlay: docker compose -f docker-compose.yml -f docker-compose.demo.yml up -d  → fms_demo
# Copy this file to backend/.env for local development.
DATABASE_URL=postgresql+psycopg2://fms:fms@localhost:5432/fms
SECRET_KEY=replace-with-random-hex
JWT_SECRET=replace-with-random-hex
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
APP_ENV=development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=notifications@fms.local
