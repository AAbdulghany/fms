# Database URL — MUST match the Docker profile you are running:
#   Hybrid dev (host API :8000, Vite :5173):
#     docker compose -f docker-compose-local.yml -f docker-compose-hybrid.yml up -d  → localhost:9432/fms_local
#   Full local stack (Docker API :9000, web :9080):
#     docker compose -f docker-compose-local.yml up -d
#   Demo stack (standalone):
#     docker compose -f docker-compose-demo.yml up -d  → localhost:5433/fms_demo (see .env.demo.example)
# Copy this file to backend/.env for local development.
DATABASE_URL=postgresql+psycopg2://fms:fms@localhost:9432/fms_local
SECRET_KEY=replace-with-random-hex
JWT_SECRET=replace-with-random-hex
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://localhost:9080
APP_ENV=development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=notifications@fms.local
