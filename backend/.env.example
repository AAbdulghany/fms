# Database URL — MUST match the Docker profile you are running.
#
# Profile A — Hybrid DEV (recommended for coding):
#   docker compose -f docker-compose-local.yml -f docker-compose-hybrid.yml up -d
#   → localhost:9432 / fms_local  +  host uvicorn :8000  +  Vite :5173
#
# Profile B — Full local Docker (UI in container):
#   docker compose -f docker-compose-local.yml up -d
#   → web :9080 / api :9000 / db :9432
#
# Profile C — Demo (sales / tunnel / E2E):
#   docker compose -f docker-compose-demo.yml up -d
#   → web :9081 / api :9001 / db :9543  (use .env.demo.example for host uvicorn)
#
# Copy:  copy backend\.env.example backend\.env
DATABASE_URL=postgresql+psycopg2://fms:fms@localhost:9432/fms_local
SECRET_KEY=dev-secret-change-me
JWT_SECRET=dev-secret-change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://localhost:9080
APP_ENV=development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=notifications@fms.local
