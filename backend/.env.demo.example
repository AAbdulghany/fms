# Local uvicorn against Docker DEMO database (fms_demo on localhost:5433)
# Copy:  copy .env.demo.example .env
# Requires: docker compose -f docker-compose-demo.yml up -d

DATABASE_URL=postgresql+psycopg2://fms:fms@localhost:5433/fms_demo
SECRET_KEY=dev-secret-change-me
JWT_SECRET=dev-secret-change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://localhost:8081
APP_ENV=demo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=notifications@fms.local
