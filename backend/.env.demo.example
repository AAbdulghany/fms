# Local uvicorn against Docker DEMO database (fms_demo on localhost:5432)
# Copy:  copy .env.demo.example .env
# Requires: docker compose -f docker-compose.yml -f docker-compose.demo.yml up -d
#           (db service only — stop fms-api-1 if port 8000 conflicts)

DATABASE_URL=postgresql+psycopg2://fms:fms@localhost:5432/fms_demo
SECRET_KEY=dev-secret-change-me
JWT_SECRET=dev-secret-change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
APP_ENV=demo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=notifications@fms.local
