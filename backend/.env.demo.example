# Host uvicorn against Docker DEMO database (fms_demo).
# Copy:  copy backend\.env.demo.example backend\.env
# Requires: docker compose -f docker-compose-demo.yml up -d db
# (from repo root — NOT from backend/)
#
# Prefer full Docker demo UI at http://localhost:9081 instead of host uvicorn.
# Only use this file when you need host API reload against the demo DB.

DATABASE_URL=postgresql+psycopg2://fms:fms@localhost:9543/fms_demo
SECRET_KEY=dev-secret-change-me
JWT_SECRET=dev-secret-change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:9081,http://localhost:9001
APP_ENV=demo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=notifications@fms.local
